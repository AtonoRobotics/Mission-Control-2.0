# Mission Control — Machine Environment Configuration
# Copy this file to .env.machines and fill in values for your deployment.
# .env.machines is gitignored — never commit real values.
# All values are required unless marked optional.

# =============================================================================
# MACHINE ADDRESSES
# =============================================================================

# Primary workstation — hosts Isaac Sim, Isaac Lab, Isaac ROS containers,
# Mission Control server, bag storage
MC_HOST_PRIMARY=

# Future: training server (Isaac Lab heavy workloads)
MC_HOST_TRAINING=

# Future: storage server (bag archive, model registry)
MC_HOST_STORAGE=

# =============================================================================
# PORTS
# =============================================================================

# rosbridge WebSocket port (inside isaac-ros-main container)
MC_ROSBRIDGE_PORT=9090

# Mission Control FastAPI backend
MC_API_PORT=8000

# Mission Control React frontend (dev server)
MC_UI_PORT=3000

# PostgreSQL
MC_DB_PORT=5432

# =============================================================================
# DATABASE
# =============================================================================

# Empirical database — robot physical properties (read-only for all agents)
MC_EMPIRICAL_DB_URL=postgresql://

# Registry database — builds, files, workflows, sessions
MC_REGISTRY_DB_URL=postgresql://

# =============================================================================
# STORAGE PATHS
# All paths are absolute on MC_HOST_PRIMARY.
# Change only the base path when moving to a new machine.
# =============================================================================

# ROS2 bag files
MC_BAG_STORAGE_PATH=

# File registry paths
MC_URDF_REGISTRY_PATH=
MC_USD_REGISTRY_PATH=
MC_CONFIG_REGISTRY_PATH=
MC_CALIBRATION_PATH=

# Training data
MC_DATASET_PATH=
MC_MODEL_PATH=

# Generated scripts
MC_SCRIPT_REGISTRY_PATH=

# =============================================================================
# ROS2
# =============================================================================

# ROS2 network domain isolation — must match value inside all containers
ROS_DOMAIN_ID=0

# =============================================================================
# ISAAC STACK
# =============================================================================

# Isaac Nucleus server (for USD asset streaming)
MC_NUCLEUS_URL=

# Isaac Sim process working directory on host
MC_ISAAC_SIM_WORKDIR=

# Isaac Lab working directory on host
MC_ISAAC_LAB_WORKDIR=

# =============================================================================
# CONTAINERS
# Names must match docker-compose.yml service names exactly.
# =============================================================================

MC_CONTAINER_ISAAC_ROS=isaac-ros-main
MC_CONTAINER_ISAAC_SIM=isaac-sim
MC_CONTAINER_ISAAC_LAB=isaac-lab
MC_CONTAINER_GROOT=groot
MC_CONTAINER_COSMOS=cosmos

# =============================================================================
# MISSION CONTROL
# =============================================================================

# Secret key for API session signing — generate with: openssl rand -hex 32
MC_SECRET_KEY=

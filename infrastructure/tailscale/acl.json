{
  "tagOwners": {
    "tag:mission-control": ["autogroup:admin"]
  },
  "groups": {
    "group:admins": [],
    "group:operators": [],
    "group:viewers": []
  },
  "acls": [
    {
      "action": "accept",
      "src": ["group:admins"],
      "dst": ["tag:mission-control:*"]
    },
    {
      "action": "accept",
      "src": ["group:operators"],
      "dst": [
        "tag:mission-control:8000",
        "tag:mission-control:9090",
        "tag:mission-control:3000",
        "tag:mission-control:22"
      ]
    },
    {
      "action": "accept",
      "src": ["group:viewers"],
      "dst": [
        "tag:mission-control:8000",
        "tag:mission-control:3000"
      ]
    },
    {
      "action": "accept",
      "src": ["tag:mission-control"],
      "dst": ["tag:mission-control:*"]
    }
  ],
  "ssh": [
    {
      "action": "accept",
      "src": ["group:admins"],
      "dst": ["tag:mission-control"],
      "users": ["root", "autogroup:nonroot"]
    },
    {
      "action": "accept",
      "src": ["group:operators"],
      "dst": ["tag:mission-control"],
      "users": ["ubuntu", "samuel"]
    }
  ]
}

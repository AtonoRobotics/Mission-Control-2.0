[Unit]
Description=Mission Control Backend (FastAPI)
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=samuel
WorkingDirectory=/home/samuel/mission-control/backend
EnvironmentFile=/home/samuel/mission-control/.env.machines
ExecStart=/home/samuel/anaconda3/bin/uvicorn main:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=3

[Install]
WantedBy=default.target

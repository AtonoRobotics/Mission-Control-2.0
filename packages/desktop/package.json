{
  "name": "@mission-control/desktop",
  "version": "0.1.0",
  "private": true,
  "main": "dist-ts/main/main.js",
  "scripts": {
    "dev": "tsc && electron dist-ts/main/main.js --dev",
    "build:ts": "tsc",
    "build:web": "pnpm --filter @mission-control/web build",
    "build": "pnpm build:ts && pnpm build:web && electron-builder --config electron-builder.yml",
    "build:linux": "pnpm build:ts && pnpm build:web && electron-builder --linux --config electron-builder.yml",
    "start": "electron dist-ts/main/main.js"
  },
  "dependencies": {
    "@mission-control/core": "workspace:*",
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "typescript": "^5.5.0"
  }
}
